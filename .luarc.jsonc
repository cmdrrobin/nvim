{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      // Runtime and builtin libraries.
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/rose-pine/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/snacks.nvim/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/conform.nvim/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/gitsigns.nvim/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/mini.icons/lua",
      "$XDG_DATA_HOME/nvim/site/pack/core/opt/oil.nvim/lua"
    ]
  }
}
